<idea-plugin>
  <id>org.epics.workbench</id>
  <name>EPICS Workbench</name>
  <vendor>EPICS Workbench</vendor>

  <description>
    <![CDATA[
      EPICS language and runtime tools for IntelliJ Platform IDEs.
    ]]>
  </description>

  <depends>com.intellij.modules.platform</depends>

  <extensions defaultExtensionNs="com.intellij">
    <fileType
      name="EPICS Database"
      language="EPICS Database"
      implementationClass="org.epics.workbench.filetypes.EpicsDatabaseFileType"
      fieldName="INSTANCE"
      extensions="db;vdb;template"
    />
    <fileType
      name="EPICS Substitutions"
      language="EPICS Substitutions"
      implementationClass="org.epics.workbench.filetypes.EpicsSubstitutionsFileType"
      fieldName="INSTANCE"
      extensions="substitutions;sub;subs"
    />
    <fileType
      name="EPICS Startup"
      language="EPICS Startup"
      implementationClass="org.epics.workbench.filetypes.EpicsStartupFileType"
      fieldName="INSTANCE"
      extensions="cmd;iocsh"
    />
    <fileType
      name="EPICS Database Definition"
      language="EPICS Database Definition"
      implementationClass="org.epics.workbench.filetypes.EpicsDatabaseDefinitionFileType"
      fieldName="INSTANCE"
      extensions="dbd"
    />
    <fileType
      name="EPICS Protocol"
      language="EPICS Protocol"
      implementationClass="org.epics.workbench.filetypes.EpicsProtocolFileType"
      fieldName="INSTANCE"
      extensions="proto"
    />
    <fileType
      name="EPICS Sequencer"
      language="EPICS Sequencer"
      implementationClass="org.epics.workbench.filetypes.EpicsSequencerFileType"
      fieldName="INSTANCE"
      extensions="st"
    />
    <fileType
      name="EPICS PV List"
      language="EPICS PV List"
      implementationClass="org.epics.workbench.filetypes.EpicsMonitorFileType"
      fieldName="INSTANCE"
      extensions="pvlist"
    />
    <fileType
      name="EPICS Probe"
      language="EPICS Probe"
      implementationClass="org.epics.workbench.filetypes.EpicsProbeFileType"
      fieldName="INSTANCE"
      extensions="probe"
    />
    <lang.syntaxHighlighterFactory
      language="EPICS Database"
      implementationClass="org.epics.workbench.highlighting.EpicsDatabaseSyntaxHighlighterFactory"
    />
    <lang.syntaxHighlighterFactory
      language="EPICS Substitutions"
      implementationClass="org.epics.workbench.highlighting.EpicsSubstitutionsSyntaxHighlighterFactory"
    />
    <lang.syntaxHighlighterFactory
      language="EPICS Startup"
      implementationClass="org.epics.workbench.highlighting.EpicsStartupSyntaxHighlighterFactory"
    />
    <lang.syntaxHighlighterFactory
      language="EPICS Database Definition"
      implementationClass="org.epics.workbench.highlighting.EpicsDatabaseDefinitionSyntaxHighlighterFactory"
    />
    <lang.syntaxHighlighterFactory
      language="EPICS Protocol"
      implementationClass="org.epics.workbench.highlighting.EpicsProtocolSyntaxHighlighterFactory"
    />
    <lang.syntaxHighlighterFactory
      language="EPICS PV List"
      implementationClass="org.epics.workbench.highlighting.EpicsMonitorSyntaxHighlighterFactory"
    />
    <lang.syntaxHighlighterFactory
      language="EPICS Probe"
      implementationClass="org.epics.workbench.highlighting.EpicsProbeSyntaxHighlighterFactory"
    />
    <notificationGroup id="EPICS Workbench Notifications" displayType="BALLOON" isLogByDefault="true" />
    <spellchecker.support
      language="EPICS Database"
      implementationClass="org.epics.workbench.spellcheck.EpicsNoSpellcheckingStrategy"
    />
    <spellchecker.support
      language="EPICS Substitutions"
      implementationClass="org.epics.workbench.spellcheck.EpicsNoSpellcheckingStrategy"
    />
    <spellchecker.support
      language="EPICS Startup"
      implementationClass="org.epics.workbench.spellcheck.EpicsNoSpellcheckingStrategy"
    />
    <spellchecker.support
      language="EPICS Database Definition"
      implementationClass="org.epics.workbench.spellcheck.EpicsNoSpellcheckingStrategy"
    />
    <spellchecker.support
      language="EPICS Protocol"
      implementationClass="org.epics.workbench.spellcheck.EpicsNoSpellcheckingStrategy"
    />
    <spellchecker.support
      language="EPICS Sequencer"
      implementationClass="org.epics.workbench.spellcheck.EpicsNoSpellcheckingStrategy"
    />
    <spellchecker.support
      language="EPICS PV List"
      implementationClass="org.epics.workbench.spellcheck.EpicsNoSpellcheckingStrategy"
    />
    <spellchecker.support
      language="EPICS Probe"
      implementationClass="org.epics.workbench.spellcheck.EpicsNoSpellcheckingStrategy"
    />
    <lang.inspectionSuppressor
      language="EPICS Database"
      implementationClass="org.epics.workbench.spellcheck.EpicsSpellcheckingInspectionSuppressor"
    />
    <lang.inspectionSuppressor
      language="EPICS Substitutions"
      implementationClass="org.epics.workbench.spellcheck.EpicsSpellcheckingInspectionSuppressor"
    />
    <lang.inspectionSuppressor
      language="EPICS Startup"
      implementationClass="org.epics.workbench.spellcheck.EpicsSpellcheckingInspectionSuppressor"
    />
    <lang.inspectionSuppressor
      language="EPICS Database Definition"
      implementationClass="org.epics.workbench.spellcheck.EpicsSpellcheckingInspectionSuppressor"
    />
    <lang.inspectionSuppressor
      language="EPICS Protocol"
      implementationClass="org.epics.workbench.spellcheck.EpicsSpellcheckingInspectionSuppressor"
    />
    <lang.inspectionSuppressor
      language="EPICS Sequencer"
      implementationClass="org.epics.workbench.spellcheck.EpicsSpellcheckingInspectionSuppressor"
    />
    <lang.inspectionSuppressor
      language="EPICS PV List"
      implementationClass="org.epics.workbench.spellcheck.EpicsSpellcheckingInspectionSuppressor"
    />
    <lang.inspectionSuppressor
      language="EPICS Probe"
      implementationClass="org.epics.workbench.spellcheck.EpicsSpellcheckingInspectionSuppressor"
    />
    <lang.quoteHandler
      language="EPICS Database"
      implementationClass="org.epics.workbench.editor.EpicsQuoteHandler"
    />
    <lang.quoteHandler
      language="EPICS Substitutions"
      implementationClass="org.epics.workbench.editor.EpicsQuoteHandler"
    />
    <lang.quoteHandler
      language="EPICS Startup"
      implementationClass="org.epics.workbench.editor.EpicsQuoteHandler"
    />
    <lang.quoteHandler
      language="EPICS Database Definition"
      implementationClass="org.epics.workbench.editor.EpicsQuoteHandler"
    />
    <lang.quoteHandler
      language="EPICS Protocol"
      implementationClass="org.epics.workbench.editor.EpicsQuoteHandler"
    />
    <lang.quoteHandler
      language="EPICS Sequencer"
      implementationClass="org.epics.workbench.editor.EpicsQuoteHandler"
    />
    <lang.quoteHandler
      language="EPICS PV List"
      implementationClass="org.epics.workbench.editor.EpicsQuoteHandler"
    />
    <lang.quoteHandler
      language="EPICS Probe"
      implementationClass="org.epics.workbench.editor.EpicsQuoteHandler"
    />
    <completion.contributor
      language="any"
      implementationClass="org.epics.workbench.completion.EpicsDatabaseCompletionContributor"
    />
    <localInspection
      language="any"
      shortName="EpicsDatabaseValueInspection"
      displayName="Validate EPICS database semantics"
      groupName="EPICS"
      enabledByDefault="true"
      level="ERROR"
      implementationClass="org.epics.workbench.inspections.EpicsDatabaseValueInspection"
    />
    <typedHandler implementation="org.epics.workbench.editor.EpicsAutoClosingTypedHandler" />
    <formattingService
      implementation="org.epics.workbench.formatting.EpicsFormattingService"
      order="first"
    />
    <externalFormatProcessor implementation="org.epics.workbench.formatting.EpicsExternalFormatProcessor" />
    <gotoDeclarationHandler implementation="org.epics.workbench.navigation.EpicsGotoDeclarationHandler" />
    <postStartupActivity implementation="org.epics.workbench.inspections.EpicsDatabaseValidationActivity" />
    <postStartupActivity implementation="org.epics.workbench.documentation.EpicsHoverDocumentationActivity" />
    <postStartupActivity implementation="org.epics.workbench.runtime.EpicsMonitorRuntimeActivity" />
    <postStartupActivity implementation="org.epics.workbench.runtime.EpicsIocStartupWatermarkActivity" />
    <projectConfigurable
      groupId="tools"
      id="org.epics.workbench.runtime.configuration"
      displayName="EPICS Workbench"
      instance="org.epics.workbench.runtime.EpicsRuntimeProjectConfigurable"
    />
    <toolWindow
      id="EPICS Workbench"
      anchor="right"
      factoryClass="org.epics.workbench.EpicsWorkbenchToolWindowFactory"
    />
    <fileEditorProvider implementation="org.epics.workbench.widget.EpicsWidgetFileEditorProvider" />
    <fileEditorProvider implementation="org.epics.workbench.widget.EpicsPvlistWidgetFileEditorProvider" />
    <fileEditorProvider implementation="org.epics.workbench.widget.EpicsMonitorWidgetFileEditorProvider" />
    <fileEditorProvider implementation="org.epics.workbench.widget.EpicsChannelGraphFileEditorProvider" />
    <fileEditorProvider implementation="org.epics.workbench.widget.EpicsIocRuntimePageFileEditorProvider" />
  </extensions>

  <actions>
    <action
      id="org.epics.workbench.ShowStatusAction"
      class="org.epics.workbench.ShowEpicsWorkbenchStatusAction"
      text="Show EPICS Workbench Status"
      description="Verify that the EPICS Workbench plugin is loaded"
    >
      <add-to-group group-id="ToolsMenu" anchor="last" />
    </action>
    <action
      id="org.epics.workbench.UpdateDatabaseTocAction"
      class="org.epics.workbench.toc.UpdateDatabaseTocAction"
      text="Update Table of Contents"
      description="Generate or refresh the EPICS record table of contents for this database file"
    />
    <action
      id="org.epics.workbench.ToggleMonitorChannelsAction"
      class="org.epics.workbench.database.ToggleMonitorChannelsAction"
      text="Start Monitor Channels"
      description="Start or stop live monitoring for database TOC channels"
    />
    <action
      id="org.epics.workbench.FormatDatabaseFileAction"
      class="org.epics.workbench.database.FormatDatabaseFileAction"
      text="Format File"
      description="Format the selected EPICS file with the EPICS formatter"
    />
    <action
      id="org.epics.workbench.CopyAllRecordNamesAction"
      class="org.epics.workbench.database.CopyAllRecordNamesAction"
      text="Copy Record Names"
      description="Copy all record names from the selected EPICS database file"
    />
    <action
      id="org.epics.workbench.CollapseAllRecordsAction"
      class="org.epics.workbench.folding.CollapseAllRecordsAction"
      text="Collapse All Records"
      description="Collapse all EPICS records in the selected database file"
    />
    <action
      id="org.epics.workbench.ExpandAllRecordsAction"
      class="org.epics.workbench.folding.ExpandAllRecordsAction"
      text="Expand All Records"
      description="Expand all EPICS records in the selected database file"
    />
    <action
      id="org.epics.workbench.ExportDatabaseToExcelAction"
      class="org.epics.workbench.export.ExportDatabaseToExcelAction"
      text="Export Database to Excel"
      description="Export the EPICS database file as an Excel workbook"
    />
    <action
      id="org.epics.workbench.CopyDatabaseAsMonitorFileAction"
      class="org.epics.workbench.monitor.CopyDatabaseAsMonitorFileAction"
      text="Copy as PV List File"
      description="Copy the selected EPICS database records as pvlist text"
    />
    <action
      id="org.epics.workbench.ImportDatabaseFromExcelAction"
      class="org.epics.workbench.export.ImportDatabaseFromExcelAction"
      text="Import Excel as Database"
      description="Import EPICS-style Excel sheets as temporary database tabs"
    />
    <action
      id="org.epics.workbench.AddDbToMakefileAction"
      class="org.epics.workbench.build.AddDbToMakefileAction"
      text="Add to Makefile"
      description="Append a DB += entry for the selected database, template, or substitutions file"
    />
    <action
      id="org.epics.workbench.BuildWithMakefileAction"
      class="org.epics.workbench.build.BuildWithMakefileAction"
      text="Build"
      description="Run make clean in the selected file's local Makefile directory"
    />
    <action
      id="org.epics.workbench.CleanAndBuildWithMakefileAction"
      class="org.epics.workbench.build.CleanAndBuildWithMakefileAction"
      text="Clean"
      description="Run make in the selected file's local Makefile directory"
    />
    <action
      id="org.epics.workbench.BuildProjectAction"
      class="org.epics.workbench.build.BuildProjectAction"
      text="Build Project"
      description="Run make in the EPICS project root"
    />
    <action
      id="org.epics.workbench.CleanAndBuildProjectAction"
      class="org.epics.workbench.build.CleanAndBuildProjectAction"
      text="Clean Project"
      description="Run make distclean in the EPICS project root"
    />
    <action
      id="org.epics.workbench.OpenExcelImportPreviewAction"
      class="org.epics.workbench.export.OpenExcelImportPreviewAction"
      text="Import Excel as Database"
      description="Choose an Excel workbook and import EPICS-style sheets as temporary database tabs"
    >
      <add-to-group group-id="ToolsMenu" anchor="last" />
    </action>
    <action
      id="org.epics.workbench.OpenInProbeAction"
      class="org.epics.workbench.probe.OpenInProbeAction"
      text="Probe"
      description="Open the current EPICS record target in a file-less probe widget"
    />
    <action
      id="org.epics.workbench.OpenInPvlistAction"
      class="org.epics.workbench.pvlist.OpenInPvlistAction"
      text="PV List"
      description="Open the current database or pvlist source in a file-less PvList widget"
    />
    <action
      id="org.epics.workbench.OpenEpicsMonitorWidgetAction"
      class="org.epics.workbench.widget.OpenEpicsMonitorWidgetAction"
      text="Open Monitor Widget"
      description="Open a file-less EPICS Monitor widget"
    >
      <add-to-group group-id="ToolsMenu" anchor="last" />
    </action>
    <action
      id="org.epics.workbench.OpenInMonitorAction"
      class="org.epics.workbench.monitor.OpenInMonitorAction"
      text="PV Monitor"
      description="Open the current EPICS channel target in a file-less Monitor widget"
    />
    <action
      id="org.epics.workbench.FindEpicsReferencesAction"
      class="org.epics.workbench.refactor.FindEpicsReferencesAction"
      text="Find EPICS References"
      description="Find EPICS references for the symbol under the caret"
    />
    <action
      id="org.epics.workbench.RenameEpicsSymbolAction"
      class="org.epics.workbench.refactor.RenameEpicsSymbolAction"
      text="Rename EPICS Symbol"
      description="Rename the EPICS symbol under the caret across the project"
    />
    <action
      id="org.epics.workbench.ManageProjectIocAction"
      class="org.epics.workbench.runtime.ManageProjectIocAction"
      text="EPICS IOC Start/Stop"
      description="Choose an IOC startup file and start, stop, or reveal its running console"
    />
    <action
      id="org.epics.workbench.StartIocAction"
      class="org.epics.workbench.runtime.StartIocAction"
      text="Start IOC"
      description="Start the selected IOC startup script inside EPICS Workbench"
    />
    <action
      id="org.epics.workbench.StopIocAction"
      class="org.epics.workbench.runtime.StopIocAction"
      text="Stop IOC"
      description="Stop the running IOC started from the selected startup file"
    />
    <action
      id="org.epics.workbench.ShowRunningTerminalAction"
      class="org.epics.workbench.runtime.ShowRunningTerminalAction"
      text="Show Running Terminal"
      description="Reveal the running IOC console for this startup file"
    />
    <action
      id="org.epics.workbench.OpenIocRuntimeCommandsAction"
      class="org.epics.workbench.runtime.OpenIocRuntimeCommandsAction"
      text="IOC Runtime Commands"
      description="Open IOC runtime commands for the running startup file"
    />
    <action
      id="org.epics.workbench.OpenIocRuntimeVariablesAction"
      class="org.epics.workbench.runtime.OpenIocRuntimeVariablesAction"
      text="IOC Runtime Variables"
      description="Open IOC runtime variables for the running startup file"
    />
    <action
      id="org.epics.workbench.OpenIocRuntimeEnvironmentAction"
      class="org.epics.workbench.runtime.OpenIocRuntimeEnvironmentAction"
      text="IOC Runtime Environment"
      description="Open IOC runtime environment variables for the running startup file"
    />
    <group
      id="org.epics.workbench.ProjectIocStartPopupGroup"
      class="org.epics.workbench.runtime.EpicsProjectIocStartPopupGroup"
      text="EPICS IOC Start"
      popup="true"
      compact="true"
    />
    <group
      id="org.epics.workbench.ProjectIocStopPopupGroup"
      class="org.epics.workbench.runtime.EpicsProjectIocStopPopupGroup"
      text="EPICS IOC Stop"
      popup="true"
      compact="true"
    />
    <group
      id="org.epics.workbench.BuildPopupGroup"
      class="org.epics.workbench.menu.EpicsBuildPopupGroup"
      text="EPICS Build"
      popup="true"
      compact="true"
    />
    <group
      id="org.epics.workbench.WidgetPopupGroup"
      class="org.epics.workbench.menu.EpicsWidgetPopupGroup"
      text="EPICS Widgets"
      popup="true"
      compact="true"
    />
    <group
      id="org.epics.workbench.ImportExportPopupGroup"
      class="org.epics.workbench.menu.EpicsImportExportPopupGroup"
      text="EPICS Import/Export"
      popup="true"
      compact="true"
    />
    <group
      id="org.epics.workbench.FormatPopupGroup"
      class="org.epics.workbench.menu.EpicsFormatPopupGroup"
      text="EPICS Format"
      popup="true"
      compact="true"
    />
    <group
      id="org.epics.workbench.DatabaseFilePopupGroup"
      class="org.epics.workbench.menu.EpicsDatabaseFilePopupGroup"
      text="EPICS Database File"
      popup="true"
      compact="true"
    />
    <group
      id="org.epics.workbench.IocRuntimePopupGroup"
      class="org.epics.workbench.menu.EpicsIocRuntimePopupGroup"
      text="EPICS IOC Runtime"
      popup="true"
      compact="true"
    />
    <group id="org.epics.workbench.EditorPopupGroup" popup="false">
      <reference ref="org.epics.workbench.ProjectIocStartPopupGroup" />
      <reference ref="org.epics.workbench.ProjectIocStopPopupGroup" />
      <reference ref="org.epics.workbench.DatabaseFilePopupGroup" />
      <reference ref="org.epics.workbench.IocRuntimePopupGroup" />
      <reference ref="org.epics.workbench.WidgetPopupGroup" />
      <reference ref="org.epics.workbench.BuildPopupGroup" />
      <reference ref="org.epics.workbench.FormatPopupGroup" />
      <reference ref="org.epics.workbench.ImportExportPopupGroup" />
      <reference ref="org.epics.workbench.FindEpicsReferencesAction" />
      <reference ref="org.epics.workbench.RenameEpicsSymbolAction" />
      <add-to-group group-id="EditorPopupMenu" anchor="first" />
    </group>
    <group id="org.epics.workbench.ProjectPopupGroup" popup="false">
      <reference ref="org.epics.workbench.ProjectIocStartPopupGroup" />
      <reference ref="org.epics.workbench.ProjectIocStopPopupGroup" />
      <reference ref="org.epics.workbench.DatabaseFilePopupGroup" />
      <reference ref="org.epics.workbench.IocRuntimePopupGroup" />
      <reference ref="org.epics.workbench.WidgetPopupGroup" />
      <reference ref="org.epics.workbench.BuildPopupGroup" />
      <reference ref="org.epics.workbench.FormatPopupGroup" />
      <reference ref="org.epics.workbench.ImportExportPopupGroup" />
      <add-to-group group-id="ProjectViewPopupMenu" anchor="first" />
    </group>
  </actions>
</idea-plugin>
