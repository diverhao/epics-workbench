<idea-plugin>
  <id>org.epics.workbench</id>
  <name>EPICS Workbench</name>
  <vendor>EPICS Workbench</vendor>

  <description>
    <![CDATA[
      EPICS language and runtime tools for IntelliJ Platform IDEs.
    ]]>
  </description>

  <depends>com.intellij.modules.platform</depends>

  <extensions defaultExtensionNs="com.intellij">
    <fileType
      name="EPICS Database"
      language="EPICS Database"
      implementationClass="org.epics.workbench.filetypes.EpicsDatabaseFileType"
      fieldName="INSTANCE"
      extensions="db;vdb;template"
    />
    <fileType
      name="EPICS Substitutions"
      language="EPICS Substitutions"
      implementationClass="org.epics.workbench.filetypes.EpicsSubstitutionsFileType"
      fieldName="INSTANCE"
      extensions="substitutions;sub;subs"
    />
    <fileType
      name="EPICS Startup"
      language="EPICS Startup"
      implementationClass="org.epics.workbench.filetypes.EpicsStartupFileType"
      fieldName="INSTANCE"
      extensions="cmd;iocsh"
    />
    <fileType
      name="EPICS Database Definition"
      language="EPICS Database Definition"
      implementationClass="org.epics.workbench.filetypes.EpicsDatabaseDefinitionFileType"
      fieldName="INSTANCE"
      extensions="dbd"
    />
    <fileType
      name="EPICS Protocol"
      language="EPICS Protocol"
      implementationClass="org.epics.workbench.filetypes.EpicsProtocolFileType"
      fieldName="INSTANCE"
      extensions="proto"
    />
    <fileType
      name="EPICS Sequencer"
      language="EPICS Sequencer"
      implementationClass="org.epics.workbench.filetypes.EpicsSequencerFileType"
      fieldName="INSTANCE"
      extensions="st"
    />
    <fileType
      name="EPICS PV List"
      language="EPICS PV List"
      implementationClass="org.epics.workbench.filetypes.EpicsMonitorFileType"
      fieldName="INSTANCE"
      extensions="pvlist"
    />
    <fileType
      name="EPICS Probe"
      language="EPICS Probe"
      implementationClass="org.epics.workbench.filetypes.EpicsProbeFileType"
      fieldName="INSTANCE"
      extensions="probe"
    />
    <lang.syntaxHighlighterFactory
      language="EPICS Database"
      implementationClass="org.epics.workbench.highlighting.EpicsDatabaseSyntaxHighlighterFactory"
    />
    <lang.syntaxHighlighterFactory
      language="EPICS Substitutions"
      implementationClass="org.epics.workbench.highlighting.EpicsSubstitutionsSyntaxHighlighterFactory"
    />
    <lang.syntaxHighlighterFactory
      language="EPICS Startup"
      implementationClass="org.epics.workbench.highlighting.EpicsStartupSyntaxHighlighterFactory"
    />
    <lang.syntaxHighlighterFactory
      language="EPICS PV List"
      implementationClass="org.epics.workbench.highlighting.EpicsMonitorSyntaxHighlighterFactory"
    />
    <lang.syntaxHighlighterFactory
      language="EPICS Probe"
      implementationClass="org.epics.workbench.highlighting.EpicsProbeSyntaxHighlighterFactory"
    />
    <spellchecker.support
      language="EPICS Database"
      implementationClass="org.epics.workbench.spellcheck.EpicsNoSpellcheckingStrategy"
    />
    <spellchecker.support
      language="EPICS Substitutions"
      implementationClass="org.epics.workbench.spellcheck.EpicsNoSpellcheckingStrategy"
    />
    <spellchecker.support
      language="EPICS Startup"
      implementationClass="org.epics.workbench.spellcheck.EpicsNoSpellcheckingStrategy"
    />
    <spellchecker.support
      language="EPICS Database Definition"
      implementationClass="org.epics.workbench.spellcheck.EpicsNoSpellcheckingStrategy"
    />
    <spellchecker.support
      language="EPICS Protocol"
      implementationClass="org.epics.workbench.spellcheck.EpicsNoSpellcheckingStrategy"
    />
    <spellchecker.support
      language="EPICS Sequencer"
      implementationClass="org.epics.workbench.spellcheck.EpicsNoSpellcheckingStrategy"
    />
    <spellchecker.support
      language="EPICS PV List"
      implementationClass="org.epics.workbench.spellcheck.EpicsNoSpellcheckingStrategy"
    />
    <spellchecker.support
      language="EPICS Probe"
      implementationClass="org.epics.workbench.spellcheck.EpicsNoSpellcheckingStrategy"
    />
    <lang.inspectionSuppressor
      language="EPICS Database"
      implementationClass="org.epics.workbench.spellcheck.EpicsSpellcheckingInspectionSuppressor"
    />
    <lang.inspectionSuppressor
      language="EPICS Substitutions"
      implementationClass="org.epics.workbench.spellcheck.EpicsSpellcheckingInspectionSuppressor"
    />
    <lang.inspectionSuppressor
      language="EPICS Startup"
      implementationClass="org.epics.workbench.spellcheck.EpicsSpellcheckingInspectionSuppressor"
    />
    <lang.inspectionSuppressor
      language="EPICS Database Definition"
      implementationClass="org.epics.workbench.spellcheck.EpicsSpellcheckingInspectionSuppressor"
    />
    <lang.inspectionSuppressor
      language="EPICS Protocol"
      implementationClass="org.epics.workbench.spellcheck.EpicsSpellcheckingInspectionSuppressor"
    />
    <lang.inspectionSuppressor
      language="EPICS Sequencer"
      implementationClass="org.epics.workbench.spellcheck.EpicsSpellcheckingInspectionSuppressor"
    />
    <lang.inspectionSuppressor
      language="EPICS PV List"
      implementationClass="org.epics.workbench.spellcheck.EpicsSpellcheckingInspectionSuppressor"
    />
    <lang.inspectionSuppressor
      language="EPICS Probe"
      implementationClass="org.epics.workbench.spellcheck.EpicsSpellcheckingInspectionSuppressor"
    />
    <lang.quoteHandler
      language="EPICS Database"
      implementationClass="org.epics.workbench.editor.EpicsQuoteHandler"
    />
    <lang.quoteHandler
      language="EPICS Substitutions"
      implementationClass="org.epics.workbench.editor.EpicsQuoteHandler"
    />
    <lang.quoteHandler
      language="EPICS Startup"
      implementationClass="org.epics.workbench.editor.EpicsQuoteHandler"
    />
    <lang.quoteHandler
      language="EPICS Database Definition"
      implementationClass="org.epics.workbench.editor.EpicsQuoteHandler"
    />
    <lang.quoteHandler
      language="EPICS Protocol"
      implementationClass="org.epics.workbench.editor.EpicsQuoteHandler"
    />
    <lang.quoteHandler
      language="EPICS Sequencer"
      implementationClass="org.epics.workbench.editor.EpicsQuoteHandler"
    />
    <lang.quoteHandler
      language="EPICS PV List"
      implementationClass="org.epics.workbench.editor.EpicsQuoteHandler"
    />
    <lang.quoteHandler
      language="EPICS Probe"
      implementationClass="org.epics.workbench.editor.EpicsQuoteHandler"
    />
    <completion.contributor
      language="any"
      implementationClass="org.epics.workbench.completion.EpicsDatabaseCompletionContributor"
    />
    <localInspection
      language="any"
      shortName="EpicsDatabaseValueInspection"
      displayName="Validate EPICS database semantics"
      groupName="EPICS"
      enabledByDefault="true"
      level="ERROR"
      implementationClass="org.epics.workbench.inspections.EpicsDatabaseValueInspection"
    />
    <typedHandler implementation="org.epics.workbench.editor.EpicsAutoClosingTypedHandler" />
    <formattingService
      implementation="org.epics.workbench.formatting.EpicsFormattingService"
      order="first"
    />
    <externalFormatProcessor implementation="org.epics.workbench.formatting.EpicsExternalFormatProcessor" />
    <gotoDeclarationHandler implementation="org.epics.workbench.navigation.EpicsGotoDeclarationHandler" />
    <postStartupActivity implementation="org.epics.workbench.inspections.EpicsDatabaseValidationActivity" />
    <postStartupActivity implementation="org.epics.workbench.documentation.EpicsHoverDocumentationActivity" />
    <postStartupActivity implementation="org.epics.workbench.runtime.EpicsMonitorRuntimeActivity" />
    <projectConfigurable
      groupId="tools"
      id="org.epics.workbench.runtime.configuration"
      instance="org.epics.workbench.runtime.EpicsRuntimeProjectConfigurable"
    />
    <toolWindow
      id="EPICS Workbench"
      anchor="right"
      factoryClass="org.epics.workbench.EpicsWorkbenchToolWindowFactory"
    />
    <fileEditorProvider implementation="org.epics.workbench.export.EpicsExcelImportPreviewFileEditorProvider" />
    <fileEditorProvider implementation="org.epics.workbench.widget.EpicsWidgetFileEditorProvider" />
    <fileEditorProvider implementation="org.epics.workbench.widget.EpicsPvlistWidgetFileEditorProvider" />
    <fileEditorProvider implementation="org.epics.workbench.widget.EpicsMonitorWidgetFileEditorProvider" />
    <fileEditorProvider implementation="org.epics.workbench.widget.EpicsChannelGraphFileEditorProvider" />
  </extensions>

  <actions>
    <action
      id="org.epics.workbench.ShowStatusAction"
      class="org.epics.workbench.ShowEpicsWorkbenchStatusAction"
      text="Show EPICS Workbench Status"
      description="Verify that the EPICS Workbench plugin is loaded"
    >
      <add-to-group group-id="ToolsMenu" anchor="last" />
    </action>
    <action
      id="org.epics.workbench.UpdateDatabaseTocAction"
      class="org.epics.workbench.toc.UpdateDatabaseTocAction"
      text="Update Table of Contents"
      description="Generate or refresh the EPICS record table of contents for this database file"
    >
      <add-to-group group-id="EditorPopupMenu" anchor="last" />
      <add-to-group group-id="ProjectViewPopupMenu" anchor="last" />
    </action>
    <action
      id="org.epics.workbench.ExportDatabaseToExcelAction"
      class="org.epics.workbench.export.ExportDatabaseToExcelAction"
      text="Export to Excel"
      description="Export the EPICS database file as an Excel workbook"
    >
      <add-to-group group-id="EditorPopupMenu" anchor="last" />
      <add-to-group group-id="ProjectViewPopupMenu" anchor="last" />
    </action>
    <action
      id="org.epics.workbench.CopyDatabaseAsMonitorFileAction"
      class="org.epics.workbench.monitor.CopyDatabaseAsMonitorFileAction"
      text="Copy as PV List File"
      description="Copy the selected EPICS database records as pvlist text"
    >
      <add-to-group group-id="EditorPopupMenu" anchor="last" />
      <add-to-group group-id="ProjectViewPopupMenu" anchor="last" />
    </action>
    <action
      id="org.epics.workbench.ImportDatabaseFromExcelAction"
      class="org.epics.workbench.export.ImportDatabaseFromExcelAction"
      text="Import as EPICS Database"
      description="Import EPICS-style Excel sheets as temporary database tabs"
    >
      <add-to-group group-id="EditorPopupMenu" anchor="last" />
      <add-to-group group-id="ProjectViewPopupMenu" anchor="last" />
    </action>
    <action
      id="org.epics.workbench.OpenExcelImportPreviewAction"
      class="org.epics.workbench.export.OpenExcelImportPreviewAction"
      text="Open Excel Import Preview"
      description="Open a preview tab that accepts dropped Excel workbooks"
    >
      <add-to-group group-id="ToolsMenu" anchor="last" />
    </action>
    <action
      id="org.epics.workbench.OpenInProbeAction"
      class="org.epics.workbench.probe.OpenInProbeAction"
      text="Probe"
      description="Open the current EPICS record target in a file-less probe widget"
    >
      <add-to-group group-id="EditorPopupMenu" anchor="last" />
    </action>
    <action
      id="org.epics.workbench.OpenInPvlistAction"
      class="org.epics.workbench.pvlist.OpenInPvlistAction"
      text="PvList"
      description="Open the current database or pvlist source in a file-less PvList widget"
    >
      <add-to-group group-id="EditorPopupMenu" anchor="last" />
      <add-to-group group-id="ProjectViewPopupMenu" anchor="last" />
    </action>
    <action
      id="org.epics.workbench.OpenEpicsMonitorWidgetAction"
      class="org.epics.workbench.widget.OpenEpicsMonitorWidgetAction"
      text="Open Monitor Widget"
      description="Open a file-less EPICS Monitor widget"
    >
      <add-to-group group-id="ToolsMenu" anchor="last" />
    </action>
    <action
      id="org.epics.workbench.OpenInMonitorAction"
      class="org.epics.workbench.monitor.OpenInMonitorAction"
      text="Monitor"
      description="Open the current EPICS channel target in a file-less Monitor widget"
    >
      <add-to-group group-id="EditorPopupMenu" anchor="last" />
      <add-to-group group-id="ProjectViewPopupMenu" anchor="last" />
    </action>
    <action
      id="org.epics.workbench.OpenInChannelGraphAction"
      class="org.epics.workbench.graph.OpenInChannelGraphAction"
      text="Channel Graph"
      description="Open the current EPICS record target in a file-less Channel Graph widget"
    >
      <add-to-group group-id="EditorPopupMenu" anchor="last" />
      <add-to-group group-id="ProjectViewPopupMenu" anchor="last" />
    </action>
  </actions>
</idea-plugin>
