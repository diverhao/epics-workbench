{
    "version": "0.0.1",
    "repository": {
        "url": "",
        "type": "git"
    },
    "publisher": "",
    "name": "epics-workbench",
    "main": "./src/extension.js",
    "scripts": {
        "sync:tdm-vendor": "node ./scripts/sync-vendored-tdm.js"
    },
    "icon": "images/epics_workbench_logo.png",
    "engines": {
        "vscode": "^1.100.0"
    },
    "displayName": "EPICS Workbench",
    "description": "EPICS syntax highlighting, autocompletion, formatting, file/record navigation, and runtime montioring tools.",
    "contributes": {
        "menus": {
            "editor/context": [
                {
                    "when": "epicsWorkbench.isEpicsProject",
                    "group": "0_epics-main@1",
                    "command": "vscode-epics.manageProjectStartupIoc"
                },
                {
                    "when": "epicsWorkbench.activeStartupCanStopIoc",
                    "group": "0_epics-main@2",
                    "submenu": "vscode-epics.iocRuntimeMenu"
                },
                {
                    "when": "editorLangId == database || epicsWorkbench.activeCanAddDbToMakefile",
                    "group": "0_epics-main@4",
                    "submenu": "vscode-epics.dbTocMenu"
                },
                {
                    "when": "epicsWorkbench.isEpicsProject || editorLangId == database || editorLangId == startup || editorLangId == substitutions || editorLangId == dbd || editorLangId == proto || editorLangId == pvlist || editorLangId == probe",
                    "group": "0_epics-main@5",
                    "submenu": "vscode-epics.widgetsMenu"
                },
                {
                    "when": "editorLangId == database || editorLangId == startup || editorLangId == substitutions || editorLangId == dbd || editorLangId == proto || editorLangId == makefile",
                    "group": "0_epics-main@6",
                    "submenu": "vscode-epics.dbFormatMenu"
                },
                {
                    "when": "epicsWorkbench.isEpicsProject || editorLangId == database || editorLangId == startup || editorLangId == substitutions || editorLangId == pvlist || editorLangId == probe || editorLangId == sequencer || editorLangId == dbd",
                    "group": "0_epics-main@7",
                    "submenu": "vscode-epics.importExportMenu"
                },
                {
                    "when": "epicsWorkbench.activeCanBuildWithMakefile || epicsWorkbench.isEpicsProject",
                    "group": "0_epics-main@8",
                    "submenu": "vscode-epics.buildMenu"
                },
                {
                    "when": "editorLangId == substitutions",
                    "group": "1_epics-misc@1",
                    "command": "vscode-epics.copyAsExpandedDb"
                },
                {
                    "when": "resourceExtname == .tdl || resourceExtname == .edl || resourceExtname == .bob || resourceExtname == .stp || resourceExtname == .plt",
                    "group": "1_epics-misc@2",
                    "command": "vscode-epics.openInTdm"
                }
            ],
            "editor/title": [
                {
                    "when": "editorLangId == startup && epicsWorkbench.activeStartupCanStartIoc",
                    "group": "navigation",
                    "command": "vscode-epics.startActiveStartupIoc"
                },
                {
                    "when": "editorLangId == startup && epicsWorkbench.activeStartupCanStopIoc",
                    "group": "navigation",
                    "command": "vscode-epics.stopActiveStartupIoc"
                },
                {
                    "when": "resourceExtname == .tdl || resourceExtname == .edl || resourceExtname == .bob || resourceExtname == .stp || resourceExtname == .plt",
                    "group": "navigation",
                    "command": "vscode-epics.openInTdm"
                }
            ],
            "commandPalette": [
                {
                    "when": "editorLangId == database",
                    "command": "vscode-epics.generateDatabaseToc"
                },
                {
                    "when": "editorLangId == database && epicsWorkbench.activeDatabaseHasToc && !epicsWorkbench.activeDatabaseMonitoringRunning",
                    "command": "vscode-epics.startDatabaseMonitorChannels"
                },
                {
                    "when": "editorLangId == database && epicsWorkbench.activeDatabaseHasToc && epicsWorkbench.activeDatabaseMonitoringRunning",
                    "command": "vscode-epics.stopDatabaseMonitorChannels"
                },
                {
                    "when": "editorLangId == database",
                    "command": "vscode-epics.openInProbe"
                },
                {
                    "when": "editorLangId == database",
                    "command": "vscode-epics.openInPvList"
                },
                {
                    "when": "editorLangId == database || editorLangId == startup || editorLangId == substitutions || editorLangId == pvlist || editorLangId == probe",
                    "command": "vscode-epics.openInMonitor"
                },
                {
                    "when": "editorLangId == startup && epicsWorkbench.activeStartupCanStartIoc",
                    "command": "vscode-epics.startActiveStartupIoc"
                },
                {
                    "when": "editorLangId == startup && epicsWorkbench.activeStartupCanStopIoc",
                    "command": "vscode-epics.stopActiveStartupIoc"
                },
                {
                    "when": "editorLangId == startup && epicsWorkbench.activeStartupCanStopIoc",
                    "command": "vscode-epics.openActiveStartupIocCommands"
                },
                {
                    "when": "editorLangId == startup && epicsWorkbench.activeStartupCanStopIoc",
                    "command": "vscode-epics.openActiveStartupIocVariables"
                },
                {
                    "when": "editorLangId == startup && epicsWorkbench.activeStartupCanStopIoc",
                    "command": "vscode-epics.openActiveStartupIocEnvironment"
                },
                {
                    "when": "editorLangId == database",
                    "command": "vscode-epics.formatDatabaseFile"
                },
                {
                    "when": "editorLangId == database",
                    "command": "vscode-epics.copyAllRecordNames"
                },
                {
                    "when": "editorLangId == database",
                    "command": "vscode-epics.expandAllRecords"
                },
                {
                    "when": "editorLangId == database",
                    "command": "vscode-epics.collapseAllRecords"
                },
                {
                    "when": "editorLangId == database || editorLangId == substitutions",
                    "command": "vscode-epics.exportDatabaseToExcel"
                },
                {
                    "when": "editorLangId == database || editorLangId == substitutions || editorLangId == startup || editorLangId == pvlist || editorLangId == probe || editorLangId == sequencer || editorLangId == dbd",
                    "command": "vscode-epics.importDatabaseFromExcel"
                },
                {
                    "when": "editorLangId == proto",
                    "command": "vscode-epics.openInProbe"
                },
                {
                    "when": "editorLangId == proto",
                    "command": "vscode-epics.openInPvList"
                },
                {
                    "when": "editorLangId == proto",
                    "command": "vscode-epics.openInMonitor"
                },
                {
                    "when": "editorLangId == proto",
                    "command": "vscode-epics.formatActiveEpicsFile"
                },
                {
                    "when": "editorLangId == dbd",
                    "command": "vscode-epics.openInProbe"
                },
                {
                    "when": "editorLangId == dbd",
                    "command": "vscode-epics.openInPvList"
                },
                {
                    "when": "editorLangId == dbd",
                    "command": "vscode-epics.openInMonitor"
                },
                {
                    "when": "editorLangId == dbd",
                    "command": "vscode-epics.formatActiveEpicsFile"
                },
                {
                    "when": "editorLangId == database || editorLangId == startup || editorLangId == substitutions",
                    "command": "vscode-epics.openInProbe"
                },
                {
                    "when": "editorLangId == database || editorLangId == startup || editorLangId == substitutions || editorLangId == pvlist",
                    "command": "vscode-epics.openInPvList"
                },
                {
                    "when": "editorLangId == database || editorLangId == startup || editorLangId == pvlist || editorLangId == probe",
                    "command": "vscode-epics.openInChannelGraph"
                },
                {
                    "when": "editorLangId == substitutions",
                    "command": "vscode-epics.copyAsExpandedDb"
                },
                {
                    "when": "epicsWorkbench.activeCanAddDbToMakefile",
                    "command": "vscode-epics.addDbToMakefile"
                },
                {
                    "when": "epicsWorkbench.activeCanBuildWithMakefile || epicsWorkbench.isEpicsProject",
                    "command": "vscode-epics.buildWithMakefile"
                },
                {
                    "when": "epicsWorkbench.activeCanBuildWithMakefile || epicsWorkbench.isEpicsProject",
                    "command": "vscode-epics.cleanAndBuildWithMakefile"
                },
                {
                    "when": "epicsWorkbench.isEpicsProject",
                    "command": "vscode-epics.buildProject"
                },
                {
                    "when": "epicsWorkbench.isEpicsProject",
                    "command": "vscode-epics.cleanAndBuildProject"
                },
                {
                    "when": "resourceExtname == .tdl || resourceExtname == .edl || resourceExtname == .bob || resourceExtname == .stp || resourceExtname == .plt",
                    "command": "vscode-epics.openInTdm"
                }
            ],
            "explorer/context": [
                {
                    "when": "epicsWorkbench.isEpicsProject && !explorerResourceIsFolder",
                    "group": "navigation@28",
                    "command": "vscode-epics.manageProjectStartupIoc"
                },
                {
                    "when": "resourceExtname == .xlsx || resourceExtname == .db || resourceExtname == .vdb || resourceExtname == .template || resourceExtname == .cmd || resourceExtname == .iocsh || resourceExtname == .sub || resourceExtname == .subs || resourceExtname == .substitutions || resourceExtname == .pvlist || resourceExtname == .probe || resourceExtname == .st || (epicsWorkbench.isEpicsProject && !explorerResourceIsFolder)",
                    "group": "navigation@29",
                    "submenu": "vscode-epics.importExportMenu"
                },
                {
                    "when": "epicsWorkbench.activeCanBuildWithMakefile || epicsWorkbench.isEpicsProject",
                    "group": "navigation@30",
                    "submenu": "vscode-epics.buildMenu"
                },
                {
                    "when": "resourceExtname == .tdl || resourceExtname == .edl || resourceExtname == .bob || resourceExtname == .stp || resourceExtname == .plt",
                    "group": "navigation@31",
                    "command": "vscode-epics.openInTdm"
                }
            ],
            "webview/context": [
                {
                    "when": "(webviewId == 'epicsWorkbench.runtimeWidget' || webviewId == 'epicsWorkbench.probeWidget' || webviewId == 'epicsWorkbench.pvlistWidget' || webviewId == 'epicsWorkbench.monitorWidget') && (epicsWorkbench.activeCanBuildWithMakefile || epicsWorkbench.isEpicsProject)",
                    "group": "0_epics-main@1",
                    "submenu": "vscode-epics.buildMenu"
                },
                {
                    "when": "webviewId == 'epicsWorkbench.runtimeWidget' || webviewId == 'epicsWorkbench.probeWidget' || webviewId == 'epicsWorkbench.pvlistWidget' || webviewId == 'epicsWorkbench.monitorWidget'",
                    "group": "0_epics-main@2",
                    "submenu": "vscode-epics.widgetsMenu"
                },
                {
                    "when": "(webviewId == 'epicsWorkbench.runtimeWidget' || webviewId == 'epicsWorkbench.probeWidget' || webviewId == 'epicsWorkbench.pvlistWidget' || webviewId == 'epicsWorkbench.monitorWidget') && (epicsWorkbench.isEpicsProject || editorLangId == database || editorLangId == startup || editorLangId == substitutions || editorLangId == pvlist || editorLangId == probe || editorLangId == sequencer || editorLangId == dbd)",
                    "group": "0_epics-main@3",
                    "submenu": "vscode-epics.importExportMenu"
                }
            ],
            "vscode-epics.dbTocMenu": [
                {
                    "when": "epicsWorkbench.activeCanAddDbToMakefile",
                    "group": "1_main@1",
                    "command": "vscode-epics.addDbToMakefile"
                },
                {
                    "when": "editorLangId == database",
                    "group": "1_main@2",
                    "command": "vscode-epics.generateDatabaseToc"
                },
                {
                    "when": "editorLangId == database && epicsWorkbench.activeDatabaseHasToc && !epicsWorkbench.activeDatabaseMonitoringRunning",
                    "group": "1_main@3",
                    "command": "vscode-epics.startDatabaseMonitorChannels"
                },
                {
                    "when": "editorLangId == database && epicsWorkbench.activeDatabaseHasToc && epicsWorkbench.activeDatabaseMonitoringRunning",
                    "group": "1_main@4",
                    "command": "vscode-epics.stopDatabaseMonitorChannels"
                }
            ],
            "vscode-epics.widgetsMenu": [
                {
                    "when": "epicsWorkbench.isEpicsProject || editorLangId == database || editorLangId == startup || editorLangId == substitutions || editorLangId == dbd || editorLangId == proto",
                    "group": "1_main@1",
                    "command": "vscode-epics.openInProbe"
                },
                {
                    "when": "epicsWorkbench.isEpicsProject || editorLangId == database || editorLangId == startup || editorLangId == substitutions || editorLangId == dbd || editorLangId == proto || editorLangId == pvlist",
                    "group": "1_main@2",
                    "command": "vscode-epics.openInPvList"
                },
                {
                    "when": "epicsWorkbench.isEpicsProject || editorLangId == database || editorLangId == startup || editorLangId == substitutions || editorLangId == dbd || editorLangId == proto || editorLangId == pvlist || editorLangId == probe",
                    "group": "1_main@3",
                    "command": "vscode-epics.openInMonitor"
                }
            ],
            "vscode-epics.dbFormatMenu": [
                {
                    "when": "editorLangId == database",
                    "group": "1_main@1",
                    "command": "vscode-epics.formatDatabaseFile"
                },
                {
                    "when": "editorLangId == substitutions || editorLangId == startup || editorLangId == dbd || editorLangId == proto || editorLangId == makefile",
                    "group": "1_main@2",
                    "command": "vscode-epics.formatActiveEpicsFile"
                },
                {
                    "when": "editorLangId == database",
                    "group": "1_main@3",
                    "command": "vscode-epics.copyAllRecordNames"
                },
                {
                    "when": "editorLangId == database",
                    "group": "1_main@4",
                    "command": "vscode-epics.expandAllRecords"
                },
                {
                    "when": "editorLangId == database",
                    "group": "1_main@5",
                    "command": "vscode-epics.collapseAllRecords"
                }
            ],
            "vscode-epics.importExportMenu": [
                {
                    "when": "editorLangId == database || resourceExtname == .db || resourceExtname == .vdb || resourceExtname == .template",
                    "group": "1_main@1",
                    "command": "vscode-epics.exportDatabaseToExcel"
                },
                {
                    "when": "epicsWorkbench.isEpicsProject || editorLangId == database || editorLangId == substitutions || editorLangId == startup || editorLangId == pvlist || editorLangId == probe || editorLangId == sequencer || editorLangId == dbd || resourceExtname == .xlsx || resourceExtname == .db || resourceExtname == .vdb || resourceExtname == .template || resourceExtname == .cmd || resourceExtname == .iocsh || resourceExtname == .sub || resourceExtname == .subs || resourceExtname == .substitutions || resourceExtname == .pvlist || resourceExtname == .probe || resourceExtname == .st || (epicsWorkbench.isEpicsProject && !explorerResourceIsFolder)",
                    "group": "1_main@2",
                    "command": "vscode-epics.importDatabaseFromExcel"
                }
            ],
            "vscode-epics.iocRuntimeMenu": [
                {
                    "when": "epicsWorkbench.activeStartupCanStopIoc",
                    "group": "1_main@1",
                    "command": "vscode-epics.showActiveStartupIocTerminal"
                },
                {
                    "when": "epicsWorkbench.activeStartupCanStopIoc",
                    "group": "1_main@2",
                    "command": "vscode-epics.openActiveStartupIocCommands"
                },
                {
                    "when": "epicsWorkbench.activeStartupCanStopIoc",
                    "group": "1_main@3",
                    "command": "vscode-epics.openActiveStartupIocVariables"
                },
                {
                    "when": "epicsWorkbench.activeStartupCanStopIoc",
                    "group": "1_main@4",
                    "command": "vscode-epics.openActiveStartupIocEnvironment"
                }
            ],
            "vscode-epics.buildMenu": [
                {
                    "when": "(epicsWorkbench.activeCanBuildWithMakefile || epicsWorkbench.isEpicsProject) && webviewId != 'epicsWorkbench.runtimeWidget' && webviewId != 'epicsWorkbench.probeWidget' && webviewId != 'epicsWorkbench.pvlistWidget' && webviewId != 'epicsWorkbench.monitorWidget'",
                    "group": "1_local@1",
                    "command": "vscode-epics.buildWithMakefile"
                },
                {
                    "when": "(epicsWorkbench.activeCanBuildWithMakefile || epicsWorkbench.isEpicsProject) && webviewId != 'epicsWorkbench.runtimeWidget' && webviewId != 'epicsWorkbench.probeWidget' && webviewId != 'epicsWorkbench.pvlistWidget' && webviewId != 'epicsWorkbench.monitorWidget'",
                    "group": "1_local@2",
                    "command": "vscode-epics.cleanAndBuildWithMakefile"
                },
                {
                    "when": "epicsWorkbench.isEpicsProject",
                    "group": "1_project@1",
                    "command": "vscode-epics.buildProject"
                },
                {
                    "when": "epicsWorkbench.isEpicsProject",
                    "group": "1_project@2",
                    "command": "vscode-epics.cleanAndBuildProject"
                }
            ]
        },
        "languages": [
            {
                "id": "database",
                "extensions": [
                    ".db",
                    ".vdb",
                    ".template"
                ],
                "configuration": "./lang-config.json",
                "aliases": [
                    "EPICS database",
                    "DB",
                    "VDB"
                ]
            },
            {
                "id": "substitutions",
                "extensions": [
                    ".substitutions",
                    ".sub",
                    ".subs"
                ],
                "configuration": "./lang-config.json",
                "aliases": [
                    "substitutions"
                ]
            },
            {
                "id": "startup",
                "extensions": [
                    ".cmd",
                    ".iocsh"
                ],
                "configuration": "./lang-config.json",
                "aliases": [
                    "startup",
                    "st.cmd"
                ]
            },
            {
                "id": "proto",
                "extensions": [
                    ".proto"
                ],
                "configuration": "./lang-config.json",
                "aliases": [
                    "StreamDevice prototypes"
                ]
            },
            {
                "id": "sequencer",
                "extensions": [
                    ".st"
                ],
                "configuration": "./lang-config.json",
                "aliases": [
                    "Sequencer"
                ]
            },
            {
                "id": "database definition",
                "extensions": [
                    ".dbd"
                ],
                "configuration": "./lang-config.json",
                "aliases": [
                    "Database definition"
                ]
            },
            {
                "id": "pvlist",
                "extensions": [
                    ".pvlist"
                ],
                "configuration": "./pvlist-language-config.json",
                "aliases": [
                    "EPICS PV List",
                    "pvlist"
                ]
            },
            {
                "id": "probe",
                "extensions": [
                    ".probe"
                ],
                "configuration": "./lang-config.json",
                "aliases": [
                    "EPICS probe",
                    "probe"
                ]
            }
        ],
        "grammars": [
            {
                "scopeName": "source.epics.db",
                "path": "./syntaxes/db.tmLanguage.json",
                "language": "database"
            },
            {
                "scopeName": "source.epics.sub",
                "path": "./syntaxes/substitutions.tmLanguage.json",
                "language": "substitutions"
            },
            {
                "scopeName": "source.epics.startup",
                "path": "./syntaxes/st.cmd.tmLanguage.json",
                "language": "startup"
            },
            {
                "scopeName": "source.epics.proto",
                "path": "./syntaxes/proto.tmLanguage.json",
                "language": "proto"
            },
            {
                "scopeName": "source.epics.seq",
                "path": "./syntaxes/seq.tmLanguage.json",
                "language": "sequencer"
            },
            {
                "scopeName": "source.epics.dbd",
                "path": "./syntaxes/dbd.tmLanguage.json",
                "language": "database definition"
            },
            {
                "scopeName": "source.epics.pvlist",
                "path": "./syntaxes/pvlist.tmLanguage.json",
                "language": "pvlist"
            },
            {
                "scopeName": "source.epics.probe",
                "path": "./syntaxes/probe.tmLanguage.json",
                "language": "probe"
            }
        ],
        "customEditors": [
            {
                "viewType": "epicsWorkbench.probeEditor",
                "displayName": "EPICS Probe",
                "selector": [
                    {
                        "filenamePattern": "*.probe"
                    }
                ],
                "priority": "default"
            },
            {
                "viewType": "epicsWorkbench.tdmEditor",
                "displayName": "TDM Display",
                "selector": [
                    {
                        "filenamePattern": "*.tdl"
                    },
                    {
                        "filenamePattern": "*.edl"
                    },
                    {
                        "filenamePattern": "*.bob"
                    },
                    {
                        "filenamePattern": "*.stp"
                    },
                    {
                        "filenamePattern": "*.plt"
                    }
                ],
                "priority": "default"
            }
        ],
        "configurationDefaults": {
            "[startup]": {
                "editor.wordBasedSuggestions": "off"
            },
            "[database]": {
                "editor.wordBasedSuggestions": "off",
                "editor.semanticHighlighting.enabled": true
            },
            "[database definition]": {
                "editor.wordBasedSuggestions": "off"
            },
            "[pvlist]": {
                "editor.wordBasedSuggestions": "off"
            },
            "[probe]": {
                "editor.wordBasedSuggestions": "off"
            }
        },
        "configuration": {
            "title": "EPICS Workbench",
            "properties": {
                "epicsWorkbench.runtime.defaultProtocol": {
                    "type": "string",
                    "enum": [
                        "ca",
                        "pva"
                    ],
                    "default": "ca",
                    "description": "Default protocol to prefer when creating runtime monitors."
                },
                "epicsWorkbench.runtime.channelCreationTimeoutSeconds": {
                    "type": "number",
                    "default": 0,
                    "minimum": 0,
                    "description": "Timeout in seconds for creating a runtime monitoring channel. Set to 0 to keep epics-tca searching and reconnecting until the channel is found."
                },
                "epicsWorkbench.runtime.monitorSubscribeTimeoutSeconds": {
                    "type": "number",
                    "default": 0,
                    "minimum": 0,
                    "description": "Timeout in seconds for the initial runtime monitor subscription. Set to 0 to keep the subscription open for epics-tca recovery and re-subscribe handling."
                },
                "epicsWorkbench.runtime.logLevel": {
                    "type": "string",
                    "enum": [
                        "DEBUG",
                        "INFO",
                        "WARN",
                        "ERROR"
                    ],
                    "default": "ERROR",
                    "description": "epics-tca log level used by the runtime monitoring context."
                },
                "epicsWorkbench.runtime.environment": {
                    "type": "object",
                    "default": {},
                    "additionalProperties": {
                        "type": "string"
                    },
                    "description": "Environment variable overrides passed to the epics-tca runtime context, for example EPICS_CA_ADDR_LIST or EPICS_PVA_ADDR_LIST."
                },
                "epicsWorkbench.tdm.rootPath": {
                    "type": "string",
                    "default": "",
                    "description": "Path to a local TDM checkout or installation root used by `externalBinary` mode. If empty, EPICS Workbench tries TDM_ROOT and a sibling ../tdm folder automatically."
                },
                "epicsWorkbench.tdm.runtimeMode": {
                    "type": "string",
                    "enum": [
                        "vendoredSource",
                        "externalBinary"
                    ],
                    "default": "vendoredSource",
                    "description": "How EPICS Workbench launches TDM. `vendoredSource` runs the copied runtime under `vscode/vendor/tdm`; `externalBinary` uses a separately built TDM executable."
                },
                "epicsWorkbench.tdm.executablePath": {
                    "type": "string",
                    "default": "",
                    "description": "Optional path to a runnable TDM executable used by `externalBinary` mode. Use this when the default packaged or Electron-based TDM launch path cannot be discovered automatically."
                },
                "epicsWorkbench.tdm.profilesPath": {
                    "type": "string",
                    "default": "",
                    "description": "Optional path to the TDM profiles.json file. If empty, EPICS Workbench uses ~/.tdm/profiles.json."
                },
                "epicsWorkbench.tdm.profile": {
                    "type": "string",
                    "default": "",
                    "description": "TDM profile name to use for the embedded display runtime. If empty, EPICS Workbench picks the first non-'For All Profiles' profile from the configured profiles file."
                },
                "epicsWorkbench.tdm.httpServerPort": {
                    "type": "number",
                    "default": 0,
                    "minimum": 0,
                    "description": "Web-mode port for the TDM subprocess. Set to 0 to let EPICS Workbench choose a free local port automatically."
                }
            }
        },
        "commands": [
            {
                "title": "Collapse All Records",
                "command": "vscode-epics.collapseAllRecords",
                "category": "EPICS"
            },
            {
                "title": "Expand All Records",
                "command": "vscode-epics.expandAllRecords",
                "category": "EPICS"
            },
            {
                "title": "Update Table of Contents",
                "command": "vscode-epics.generateDatabaseToc",
                "category": "EPICS"
