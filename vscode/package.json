{
    "version": "0.0.1",
    "repository": {
        "url": "",
        "type": "git"
    },
    "publisher": "",
    "name": "epics-workbench",
    "main": "./src/extension.js",
    "icon": "images/epics_workbench_logo.png",
    "engines": {
        "vscode": "^1.100.0"
    },
    "displayName": "EPICS Workbench",
    "description": "EPICS syntax highlighting, autocompletion, formatting, file/record navigation, and runtime montioring tools.",
    "contributes": {
        "views": {
            "explorer": [
                {
                    "id": "epicsRuntimeMonitors",
                    "name": "EPICS Runtime"
                }
            ]
        },
        "menus": {
            "editor/context": [
                {
                    "when": "editorLangId == database",
                    "group": "0_epics-db-main@1",
                    "command": "vscode-epics.generateDatabaseToc"
                },
                {
                    "when": "editorLangId == database && epicsWorkbench.activeDatabaseHasToc && !epicsWorkbench.activeDatabaseMonitoringRunning",
                    "group": "0_epics-db-main@2",
                    "command": "vscode-epics.startDatabaseMonitorChannels"
                },
                {
                    "when": "editorLangId == database && epicsWorkbench.activeDatabaseHasToc && epicsWorkbench.activeDatabaseMonitoringRunning",
                    "group": "0_epics-db-main@2",
                    "command": "vscode-epics.stopDatabaseMonitorChannels"
                },
                {
                    "when": "editorLangId == database",
                    "group": "0_epics-db-main@3",
                    "command": "vscode-epics.openInProbe"
                },
                {
                    "when": "editorLangId == database",
                    "group": "0_epics-db-main@4",
                    "command": "vscode-epics.openInPvList"
                },
                {
                    "when": "editorLangId == database",
                    "group": "0_epics-db-main@5",
                    "command": "vscode-epics.openInMonitor"
                },
                {
                    "when": "editorLangId == database",
                    "group": "0_epics-db-format@1",
                    "command": "vscode-epics.formatDatabaseFile"
                },
                {
                    "when": "editorLangId == database",
                    "group": "0_epics-db-format@2",
                    "command": "vscode-epics.copyAllRecordNames"
                },
                {
                    "when": "editorLangId == database",
                    "group": "0_epics-db-format@3",
                    "command": "vscode-epics.expandAllRecords"
                },
                {
                    "when": "editorLangId == database",
                    "group": "0_epics-db-format@4",
                    "command": "vscode-epics.collapseAllRecords"
                },
                {
                    "when": "editorLangId == database",
                    "group": "0_epics-db-excel@1",
                    "command": "vscode-epics.exportDatabaseToExcel"
                },
                {
                    "when": "editorLangId == database || editorLangId == pvlist || editorLangId == probe || editorLangId == sequencer || editorLangId == proto",
                    "group": "0_epics-db-excel@2",
                    "command": "vscode-epics.importDatabaseFromExcel"
                },
                {
                    "when": "editorLangId == substitutions",
                    "group": "navigation@30",
                    "command": "vscode-epics.exportDatabaseToExcel"
                },
                {
                    "when": "editorLangId == substitutions",
                    "group": "navigation@31",
                    "command": "vscode-epics.importDatabaseFromExcelShort"
                },
                {
                    "when": "editorLangId == substitutions",
                    "group": "navigation@32",
                    "command": "vscode-epics.formatActiveEpicsFile"
                },
                {
                    "when": "editorLangId == substitutions",
                    "group": "navigation@33",
                    "command": "vscode-epics.openInProbe"
                },
                {
                    "when": "editorLangId == substitutions",
                    "group": "navigation@34",
                    "command": "vscode-epics.openInPvList"
                },
                {
                    "when": "editorLangId == substitutions",
                    "group": "navigation@35",
                    "command": "vscode-epics.openInMonitor"
                },
                {
                    "when": "editorLangId == startup",
                    "group": "navigation@29",
                    "command": "vscode-epics.openInProbe"
                },
                {
                    "when": "editorLangId == startup",
                    "group": "navigation@30",
                    "command": "vscode-epics.openInPvList"
                },
                {
                    "when": "editorLangId == startup",
                    "group": "navigation@31",
                    "command": "vscode-epics.openInMonitor"
                },
                {
                    "when": "editorLangId == startup",
                    "group": "navigation@32",
                    "command": "vscode-epics.formatActiveEpicsFile"
                },
                {
                    "when": "editorLangId == startup",
                    "group": "navigation@33",
                    "command": "vscode-epics.importDatabaseFromExcelShort"
                },
                {
                    "when": "editorLangId == pvlist",
                    "group": "navigation@31",
                    "command": "vscode-epics.openInPvList"
                },
                {
                    "when": "editorLangId == pvlist",
                    "group": "navigation@32",
                    "command": "vscode-epics.openInMonitor"
                },
                {
                    "when": "editorLangId == probe",
                    "group": "navigation@33",
                    "command": "vscode-epics.openInMonitor"
                }
            ],
            "commandPalette": [
                {
                    "when": "editorLangId == database",
                    "command": "vscode-epics.generateDatabaseToc"
                },
                {
                    "when": "editorLangId == database && epicsWorkbench.activeDatabaseHasToc && !epicsWorkbench.activeDatabaseMonitoringRunning",
                    "command": "vscode-epics.startDatabaseMonitorChannels"
                },
                {
                    "when": "editorLangId == database && epicsWorkbench.activeDatabaseHasToc && epicsWorkbench.activeDatabaseMonitoringRunning",
                    "command": "vscode-epics.stopDatabaseMonitorChannels"
                },
                {
                    "when": "editorLangId == database",
                    "command": "vscode-epics.openInProbe"
                },
                {
                    "when": "editorLangId == database",
                    "command": "vscode-epics.openInPvList"
                },
                {
                    "when": "editorLangId == database || editorLangId == startup || editorLangId == substitutions || editorLangId == pvlist || editorLangId == probe",
                    "command": "vscode-epics.openInMonitor"
                },
                {
                    "when": "editorLangId == database",
                    "command": "vscode-epics.formatDatabaseFile"
                },
                {
                    "when": "editorLangId == database",
                    "command": "vscode-epics.copyAllRecordNames"
                },
                {
                    "when": "editorLangId == database",
                    "command": "vscode-epics.expandAllRecords"
                },
                {
                    "when": "editorLangId == database",
                    "command": "vscode-epics.collapseAllRecords"
                },
                {
                    "when": "editorLangId == database || editorLangId == substitutions",
                    "command": "vscode-epics.exportDatabaseToExcel"
                },
                {
                    "when": "editorLangId == database || editorLangId == substitutions || editorLangId == pvlist || editorLangId == probe || editorLangId == sequencer || editorLangId == proto",
                    "command": "vscode-epics.importDatabaseFromExcel"
                },
                {
                    "when": "editorLangId == database || editorLangId == startup || editorLangId == substitutions",
                    "command": "vscode-epics.openInProbe"
                },
                {
                    "when": "editorLangId == database || editorLangId == startup || editorLangId == substitutions || editorLangId == pvlist",
                    "command": "vscode-epics.openInPvList"
                },
                {
                    "when": "editorLangId == database || editorLangId == startup || editorLangId == pvlist || editorLangId == probe",
                    "command": "vscode-epics.openInChannelGraph"
                },
                {
                    "when": "editorLangId == substitutions",
                    "command": "vscode-epics.copyAsExpandedDb"
                }
            ],
            "view/item/context": [
                {
                    "when": "view == epicsRuntimeMonitors && viewItem == epicsRuntimeMonitor",
                    "command": "vscode-epics.removeRuntimeMonitor",
                    "group": "inline"
                }
            ],
            "view/title": [
                {
                    "when": "view == epicsRuntimeMonitors",
                    "command": "vscode-epics.addRuntimeMonitor",
                    "group": "navigation"
                },
                {
                    "when": "view == epicsRuntimeMonitors",
                    "command": "vscode-epics.openProjectRuntimeConfiguration",
                    "group": "navigation"
                },
                {
                    "when": "view == epicsRuntimeMonitors",
                    "command": "vscode-epics.restartRuntimeContext",
                    "group": "navigation"
                },
                {
                    "when": "view == epicsRuntimeMonitors",
                    "command": "vscode-epics.stopRuntimeContext",
                    "group": "navigation"
                },
                {
                    "when": "view == epicsRuntimeMonitors",
                    "command": "vscode-epics.clearRuntimeMonitors",
                    "group": "navigation"
                }
            ],
            "explorer/context": [
                {
                    "when": "resourceExtname == .xlsx || resourceExtname == .db || resourceExtname == .vdb || resourceExtname == .template || resourceExtname == .cmd || resourceExtname == .iocsh || resourceExtname == .sub || resourceExtname == .subs || resourceExtname == .substitutions || resourceExtname == .pvlist || resourceExtname == .probe || resourceExtname == .st || resourceExtname == .proto || (epicsWorkbench.isEpicsProject && !explorerResourceIsFolder)",
                    "group": "navigation@30",
                    "command": "vscode-epics.importDatabaseFromExcel"
                }
            ]
        },
        "languages": [
            {
                "id": "database",
                "extensions": [
                    ".db",
                    ".vdb",
                    ".template"
                ],
                "configuration": "./lang-config.json",
                "aliases": [
                    "EPICS database",
                    "DB",
                    "VDB"
                ]
            },
            {
                "id": "substitutions",
                "extensions": [
                    ".substitutions",
                    ".sub",
                    ".subs"
                ],
                "configuration": "./lang-config.json",
                "aliases": [
                    "substitutions"
                ]
            },
            {
                "id": "startup",
                "extensions": [
                    ".cmd",
                    ".iocsh"
                ],
                "configuration": "./lang-config.json",
                "aliases": [
                    "startup",
                    "st.cmd"
                ]
            },
            {
                "id": "proto",
                "extensions": [
                    ".proto"
                ],
                "configuration": "./lang-config.json",
                "aliases": [
                    "StreamDevice prototypes"
                ]
            },
            {
                "id": "sequencer",
                "extensions": [
                    ".st"
                ],
                "configuration": "./lang-config.json",
                "aliases": [
                    "Sequencer"
                ]
            },
            {
                "id": "database definition",
                "extensions": [
                    ".dbd"
                ],
                "configuration": "./lang-config.json",
                "aliases": [
                    "Database definition"
                ]
            },
            {
                "id": "pvlist",
                "extensions": [
                    ".pvlist"
                ],
                "configuration": "./pvlist-language-config.json",
                "aliases": [
                    "EPICS PV List",
                    "pvlist"
                ]
            },
            {
                "id": "probe",
                "extensions": [
                    ".probe"
                ],
                "configuration": "./lang-config.json",
                "aliases": [
                    "EPICS probe",
                    "probe"
                ]
            }
        ],
        "grammars": [
            {
                "scopeName": "source.epics.db",
                "path": "./syntaxes/db.tmLanguage.json",
                "language": "database"
            },
            {
                "scopeName": "source.epics.sub",
                "path": "./syntaxes/substitutions.tmLanguage.json",
                "language": "substitutions"
            },
            {
                "scopeName": "source.epics.startup",
                "path": "./syntaxes/st.cmd.tmLanguage.json",
                "language": "startup"
            },
            {
                "scopeName": "source.epics.proto",
                "path": "./syntaxes/proto.tmLanguage.json",
                "language": "proto"
            },
            {
                "scopeName": "source.epics.seq",
                "path": "./syntaxes/seq.tmLanguage.json",
                "language": "sequencer"
            },
            {
                "scopeName": "source.epics.dbd",
                "path": "./syntaxes/dbd.tmLanguage.json",
                "language": "database definition"
            },
            {
                "scopeName": "source.epics.pvlist",
                "path": "./syntaxes/pvlist.tmLanguage.json",
                "language": "pvlist"
            },
            {
                "scopeName": "source.epics.probe",
                "path": "./syntaxes/probe.tmLanguage.json",
                "language": "probe"
            }
        ],
        "customEditors": [
            {
                "viewType": "epicsWorkbench.probeEditor",
                "displayName": "EPICS Probe",
                "selector": [
                    {
                        "filenamePattern": "*.probe"
                    }
                ],
                "priority": "default"
            }
        ],
        "configurationDefaults": {
            "[startup]": {
                "editor.wordBasedSuggestions": "off"
            },
            "[database]": {
                "editor.wordBasedSuggestions": "off",
                "editor.semanticHighlighting.enabled": true
            },
            "[database definition]": {
                "editor.wordBasedSuggestions": "off"
            },
            "[pvlist]": {
                "editor.wordBasedSuggestions": "off"
            },
            "[probe]": {
                "editor.wordBasedSuggestions": "off"
            }
        },
        "configuration": {
            "title": "EPICS Workbench",
            "properties": {
                "epicsWorkbench.runtime.defaultProtocol": {
                    "type": "string",
                    "enum": [
                        "ca",
                        "pva"
                    ],
                    "default": "ca",
                    "description": "Default protocol to prefer when creating runtime monitors."
                },
                "epicsWorkbench.runtime.channelCreationTimeoutSeconds": {
                    "type": "number",
                    "default": 0,
                    "minimum": 0,
                    "description": "Timeout in seconds for creating a runtime monitoring channel. Set to 0 to keep epics-tca searching and reconnecting until the channel is found."
                },
                "epicsWorkbench.runtime.monitorSubscribeTimeoutSeconds": {
                    "type": "number",
                    "default": 0,
                    "minimum": 0,
                    "description": "Timeout in seconds for the initial runtime monitor subscription. Set to 0 to keep the subscription open for epics-tca recovery and re-subscribe handling."
                },
                "epicsWorkbench.runtime.logLevel": {
                    "type": "string",
                    "enum": [
                        "DEBUG",
                        "INFO",
                        "WARN",
                        "ERROR"
                    ],
                    "default": "ERROR",
                    "description": "epics-tca log level used by the runtime monitoring context."
                },
                "epicsWorkbench.runtime.environment": {
                    "type": "object",
                    "default": {},
                    "additionalProperties": {
                        "type": "string"
                    },
                    "description": "Environment variable overrides passed to the epics-tca runtime context, for example EPICS_CA_ADDR_LIST or EPICS_PVA_ADDR_LIST."
                }
            }
        },
        "commands": [
            {
                "title": "Collapse All Records",
                "command": "vscode-epics.collapseAllRecords",
                "category": "EPICS"
            },
            {
                "title": "Expand All Records",
                "command": "vscode-epics.expandAllRecords",
                "category": "EPICS"
            },
            {
                "title": "Update Table of Contents",
                "command": "vscode-epics.generateDatabaseToc",
                "category": "EPICS"
            },
            {
                "title": "Start Monitor Channels",
                "command": "vscode-epics.startDatabaseMonitorChannels",
                "category": "EPICS"
            },
            {
                "title": "Stop Monitor Channels",
                "command": "vscode-epics.stopDatabaseMonitorChannels",
                "category": "EPICS"
            },
            {
                "title": "Format DB File",
                "command": "vscode-epics.formatDatabaseFile",
                "category": "EPICS"
            },
            {
                "title": "Format File",
                "command": "vscode-epics.formatActiveEpicsFile",
                "category": "EPICS"
            },
            {
                "title": "Copy All Record Names",
                "command": "vscode-epics.copyAllRecordNames",
                "category": "EPICS"
            },
            {
                "title": "Copy as expanded db",
                "command": "vscode-epics.copyAsExpandedDb",
                "category": "EPICS"
            },
            {
                "title": "Export Excel",
                "command": "vscode-epics.exportDatabaseToExcel",
                "category": "EPICS"
            },
            {
                "title": "Import Excel as EPICS DB",
                "command": "vscode-epics.importDatabaseFromExcel",
                "category": "EPICS"
            },
            {
                "title": "Import Excel",
                "command": "vscode-epics.importDatabaseFromExcelShort",
                "category": "EPICS"
            },
            {
                "title": "Open Excel Import Preview",
                "command": "vscode-epics.openExcelImportPreview",
                "category": "EPICS"
            },
            {
                "title": "Probe",
                "command": "vscode-epics.openInProbe",
                "category": "EPICS"
            },
            {
                "title": "PV List",
                "command": "vscode-epics.openInPvList",
                "category": "EPICS"
            },
            {
                "title": "PV Monitor",
                "command": "vscode-epics.openInMonitor",
                "category": "EPICS"
            },
            {
                "title": "Channel Graph",
                "command": "vscode-epics.openInChannelGraph",
                "category": "EPICS"
            },
            {
                "title": "Add Runtime Monitor",
                "command": "vscode-epics.addRuntimeMonitor",
                "category": "EPICS"
            },
            {
                "title": "Remove Runtime Monitor",
                "command": "vscode-epics.removeRuntimeMonitor",
                "category": "EPICS"
            },
            {
                "title": "Clear Runtime Monitors",
                "command": "vscode-epics.clearRuntimeMonitors",
                "category": "EPICS"
            },
            {
                "title": "Restart Runtime Context",
                "command": "vscode-epics.restartRuntimeContext",
                "category": "EPICS"
            },
            {
                "title": "Stop Runtime Context",
                "command": "vscode-epics.stopRuntimeContext",
                "category": "EPICS"
            },
            {
                "title": "Start Runtime For Active File",
                "command": "vscode-epics.startActiveFileRuntimeContext",
                "category": "EPICS"
            },
            {
                "title": "Stop Runtime For Active File",
                "command": "vscode-epics.stopActiveFileRuntimeContext",
                "category": "EPICS"
            },
            {
                "title": "Put Runtime Value",
                "command": "vscode-epics.putRuntimeValue",
                "category": "EPICS"
            },
            {
                "title": "Open Project Runtime Configuration",
                "command": "vscode-epics.openProjectRuntimeConfiguration",
                "category": "EPICS"
            }
        ]
    },
    "categories": [
        "Programming Languages",
        "Snippets"
    ],
    "activationEvents": [
        "onLanguage:database",
        "onLanguage:startup",
        "onLanguage:substitutions",
        "onLanguage:sequencer",
        "onLanguage:pvlist",
        "onLanguage:probe",
        "onLanguage:database definition",
        "onCustomEditor:epicsWorkbench.probeEditor",
        "onLanguage:makefile",
        "onView:epicsRuntimeMonitors",
        "onCommand:vscode-epics.copyAsMonitorFile",
        "onCommand:vscode-epics.copyAsExpandedDb",
        "onCommand:vscode-epics.exportDatabaseToExcel",
        "onCommand:vscode-epics.openInProbe",
        "onCommand:vscode-epics.openInChannelGraph",
        "onCommand:vscode-epics.openInMonitor",
        "onCommand:vscode-epics.addRuntimeMonitor",
        "onCommand:vscode-epics.removeRuntimeMonitor",
        "onCommand:vscode-epics.clearRuntimeMonitors",
        "onCommand:vscode-epics.restartRuntimeContext",
        "onCommand:vscode-epics.stopRuntimeContext",
        "onCommand:vscode-epics.startActiveFileRuntimeContext",
        "onCommand:vscode-epics.stopActiveFileRuntimeContext",
        "onCommand:vscode-epics.putRuntimeValue",
        "onCommand:vscode-epics.openProjectRuntimeConfiguration"
    ],
    "dependencies": {
        "epics-tca": "^1.1.33"
    },
    "__metadata": {
        "publisherId": "",
        "publisherDisplayName": "",
        "id": ""
    }
}
