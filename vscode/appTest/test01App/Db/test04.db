# EPICS TOC BEGIN
# Macros:
#  - S = val
# Table of Contents
# | Record | Value              | Type |
# | ------ | ------------------ | ---- |
# | $(S)1  |                    | ai   |
# | val2   |                    | ai   |
# | $(S)2  |                    | aSub |
# EPICS TOC END

record(ai, "$(S)1") {
    field(DESC, "")
}

record(ai, "val2") {
    field(DESC, "")
    field(DTYP, "")
    field(SCAN, "Passive")
    field(INP, "")
    field(FLNK, "$(S)2")
}

record(aSub, "$(S)2") {
    field(DESC, "")
    field(SNAM, "")
    field(EFLG, "ON CHANGE")
    field(INPA, "")
    field(FTA, "DOUBLE")
    field(NOA, "1")
    field(OUTA, "")
    field(FTVA, "DOUBLE")
    field(NOVA, "1")
}