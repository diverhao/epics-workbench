# | $(S):MAG_NAME             |                    | stringin  | stream | @4g.proto get-mag-name $(BUS)             | NA                                        |
# | $(S):RESET_QUENCH_COND    |                    | ao        | stream | NA                                        | @4g.proto reset-quench-cond $(BUS)        |
