# EPICS TOC END

record(ao, "$(S):SET_CURR_SWEEP_LLIM4") {
    field(DESC, "")
    field(PREC, "0")
    field(EGU, "")
    field(DRVL, "0")
    field(DRVH, "0")
    field(VAL, "0")
}

