record(mbbo, "$(S):SWEEP") {
    field(DESC, "Start output current sweep")
    field(DTYP, "stream")
    field(OMSL, "supervisory")
    field(ZRST, "ZERO")
    field(ONST, "PAUSE")
    field(TWST, "UP")
    field(THST, "DOWN")
    field(OUT, "@4g.proto sweep $(BUS)")
}

record(mbbo, "$(S):SWEEP_FAST") {
    field(DESC, "Start output current sweep fast")
    field(DTYP, "stream")
    field(OMSL, "supervisory")
    field(ZRST, "ZERO")
    field(ONST, "PAUSE")
    field(TWST, "UP")
    field(THST, "DOWN")
    field(OUT, "@4g.proto sweep-fast $(BUS)")
}

record(mbbi, "$(S):SWEEP_STATUS") {
    field(DESC, "Query sweep mode")
    field(DTYP, "stream")
    field(ZRST, "zeroing")
    field(ONST, "sweep paused")
    field(TWST, "sweep up")
    field(THST, "sweep down")
    field(INP, "@4g.proto sweep-status $(BUS)")
}

