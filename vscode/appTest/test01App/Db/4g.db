    field(DLY8, "0.2")
    field(DOL9, "1")
    field(DLY9, "0.2")
    field(DOLA, "1")
    field(DLYA, "0.2")
    field(DOLB, "1")
    field(DLYB, "0.2")
    field(DOLC, "1")
    field(DLYC, "0.2")
    field(DOLD, "1")
    field(DLYD, "0.2")
    field(DOLE, "1")
    field(DLYE, "0.2")
    field(DOLF, "1")
    field(DLYF, "0.2")
    field(LNK0, "$(S):REPORT_ERR.PROC")
    field(LNK1, "$(S):MAG_NAME.PROC")
    field(LNK2, "$(S):ESR.PROC")
