record(bo, "$(S):SET_REPORT_ERR") {
    field(DESC, "Set error response mode")
    field(DTYP, "stream")
    field(ONAM, "REPORT")
    field(ZNAM, "NOT REPORT")
    field(OUT, "@4g.proto set-error-mode $(BUS)")
}

record(bi, "$(S):REPORT_ERR") {
    field(DESC, "Set error response mode")
    field(DTYP, "stream")
    field(ONAM, "REPORT")
    field(ZNAM, "NOT REPORT")
    field(INP, "@4g.proto get-error-mode $(BUS)")
}

record(bo, "$(S):SET_REMOTE") {
    field(DESC, "set to REMOTE or LOCAL")
    field(DTYP, "stream")
    field(ONAM, "LOCAL")
    field(ZNAM, "REMOTE")
    field(OMSL, "supervisory")
    field(OUT, "@4g.proto set-remote $(BUS)")
}

record(stringout, "$(S):SET_MAG_NAME") {
    field(DESC, "Sets the name of the coil")
    field(DTYP, "stream")
    field(OMSL, "supervisory")
    field(OUT, "@4g.proto set-mag-name $(BUS)")
}

record(stringin, "$(S):MAG_NAME") {
    field(DESC, "Query the name of the selected coil")
    field(DTYP, "stream")
    field(INP, "@4g.proto get-mag-name $(BUS)")
}

record(ao, "$(S):RESET_QUENCH_COND") {
    field(DESC, "Reset quench cond, returns to STANDBY")
    field(DTYP, "stream")
    field(OMSL, "closed_loop")
    field(OUT, "@4g.proto reset-quench-cond $(BUS)")
}


record(ao, "$(S):CLEAR_ESR") {
    field(DESC, "Clear ESR")
    field(OMSL, "supervisory")
    field(DTYP, "stream")
    field(OUT, "@4g.proto clear-status $(BUS)")
}

record(longin, "$(S):ESR") {
    field(DESC, "Standard Event Status Register Query")
    field(DTYP, "stream")
    field(INP, "@4g.proto get-esr $(BUS)")
}

record(stringin, "$(S):ID") {
    field(DESC, "Identification Query")
    field(DTYP, "stream")
    field(INP, "@4g.proto get-id $(BUS)")
}

record(longin, "$(S):STATUS_BYTE") {
    field(DESC, "Read Status Byte Query")
    field(DTYP, "stream")
    field(INP, "@4g.proto get-status-byte $(BUS)")
}

