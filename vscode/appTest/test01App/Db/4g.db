# | $(S):UPDATE_2             |                    | seq       | ""     | NA                                        | NA                                        |
# | $(S):SET_REPORT_ERR       |                    | bo        | stream | NA                                        | @4g.proto set-error-mode $(BUS)           |
# | $(S):REPORT_ERR           |                    | bi        | stream | @4g.proto get-error-mode $(BUS)           | NA                                        |
