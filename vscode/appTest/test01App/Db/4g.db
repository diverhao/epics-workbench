    field(LNK5, "CURR_SWEEP_LLIM")
    field(LNK6, "$(S):CURR_SWEEP_ULIM.PROC")
    field(LNK7, "$(S):SWEEP_RANGE_0.PROC")
    field(LNK8, "$(S):SWEEP_RANGE_1.PROC")
    field(LNK9, "$(S):SWEEP_RANGE_2.PROC")
    field(LNKA, "$(S):SWEEP_RANGE_3.PROC")
