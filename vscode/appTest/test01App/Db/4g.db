# | $(S):ID                   |                    | stringin  | stream | @4g.proto get-id $(BUS)                   | NA                                        |
# | $(S):STATUS_BYTE          |                    | longin    | stream | @4g.proto get-status-byte $(BUS)          | NA                                        |
# | $(S):SET_CURR_SWEEP_LLIM  |                    | ao        | stream | NA                                        | @4g.proto set-curr-sweep-low-limit $(BUS) |
# | CURR_SWEEP_LLIM           |                    | ai        | stream | @4g.proto get-curr-sweep-low-limit $(BUS) | NA                                        |
# | $(S):SET_CURR_SWEEP_ULIM  |                    | ao        | stream | NA                                        | @4g.proto set-curr-sweep-up-limit $(BUS)  |
# | $(S):CURR_SWEEP_ULIM      |                    | ai        | stream | @4g.proto get-curr-sweep-up-limit $(BUS)  | NA                                        |
# | $(S):SET_SWEEP_RANGE_0    |                    | ao        | stream | NA                                        | @4g.proto set-sweep-range(0) $(BUS)       |
# | $(S):SET_SWEEP_RANGE_1    |                    | ao        | stream | NA                                        | @4g.proto set-sweep-range(1) $(BUS)       |
# | $(S):SET_SWEEP_RANGE_2    |                    | ao        | stream | NA                                        | @4g.proto set-sweep-range(2) $(BUS)       |
# | $(S):SET_SWEEP_RANGE_3    |                    | ao        | stream | NA                                        | @4g.proto set-sweep-range(3) $(BUS)       |
# | $(S):SET_SWEEP_RANGE_4    |                    | ao        | stream | NA                                        | @4g.proto set-sweep-range(4) $(BUS)       |
# | $(S):SWEEP_RANGE_0        |                    | ai        | stream | @4g.proto get-sweep-range(0) $(BUS)       | NA                                        |
# | $(S):SWEEP_RANGE_1        |                    | ai        | stream | @4g.proto get-sweep-range(1) $(BUS)       | NA                                        |
# | $(S):SWEEP_RANGE_2        |                    | ai        | stream | @4g.proto get-sweep-range(2) $(BUS)       | NA                                        |
# | $(S):SWEEP_RANGE_3        |                    | ai        | stream | @4g.proto get-sweep-range(3) $(BUS)       | NA                                        |
# | $(S):SWEEP_RANGE_4        |                    | ai        | stream | @4g.proto get-sweep-range(4) $(BUS)       | NA                                        |
# | $(S):SET_SWEEP_RATE_0     |                    | ao        | stream | NA                                        | @4g.proto set-sweep-rate(0) $(BUS)        |
# | $(S):SET_SWEEP_RATE_1     |                    | ao        | stream | NA                                        | @4g.proto set-sweep-rate(1) $(BUS)        |
