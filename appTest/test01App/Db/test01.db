record(ai, "$(SYS)3") {
    field(FLNK, "val5")
    field(SCAN, "5 second")
    field(INP, "$(SYS)2")
}

record(ai, "$(SYS)4") {
    field(SCAN, "2 second")
    field(DTYP, "Add10")
}

